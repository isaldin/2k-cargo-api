APP_PORT={{ app_port }}
APP_MASTER_KEY={{ app_master_key }}
SITE_BASE_URL={{ site_base_url }}
DATABASE_PATH={{ database_path }}
DATABASE_SYNCHRONIZE={{ database_synchronize | bool | ternary('true', 'false') }}
PACKAGE_SCAN_PAGE_LIMIT={{ package_scan_page_limit }}
AUTO_RELOGIN_RETRY_LIMIT={{ auto_relogin_retry_limit }}
{% if session_ttl_seconds is defined and session_ttl_seconds not in [none, ""] %}
SESSION_TTL_SECONDS={{ session_ttl_seconds }}
{% endif %}
LOG_LEVEL={{ log_level | default('info') }}
LOG_FORMAT={{ log_format | default('json') }}
LOG_STACKS={{ log_stacks | default(false) | bool | ternary('true', 'false') }}
